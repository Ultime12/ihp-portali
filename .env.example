# İstemciye aktarılabilir Supabase proje bilgileri.
# SUPABASE_ANON_KEY gizli değildir; RLS politikaları yine de zorunludur.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Yalnızca Vercel sunucu fonksiyonlarında kullanılır. Tarayıcıya aktarılmaz.
# Üye daveti gibi yönetici işlemleri için gereklidir.
SUPABASE_SERVICE_ROLE_KEY=

# Sunucu tarafli e-posta bildirimleri icin kullanilir. Tarayiciya aktarilmaz.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
MAIL_ENABLED=false
MAIL_FROM=İHP Portalı <bildirim@ihp.org.tr>
SITE_URL=https://ihp.org.tr

# Opsiyonel bildirim anahtarlari. Bos birakilirsa Supabase Vault kullanilir.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:sistem@ihp.org.tr
PUSH_WEBHOOK_SECRET=
